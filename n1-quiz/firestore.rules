rules_version = '2';

// Firestore Security Rules cho N1 quiz.
// Dán toàn bộ nội dung này vào: Firebase Console → Firestore Database → Rules → Publish.
// (File này chỉ để lưu/tham khảo; sửa rule phải làm trong Console.)

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'ks235278@kaichi.ac.jp';
    }

    // Hồ sơ tài khoản. Hạn dùng (paidUntil) & approved CHỈ admin được ghi.
    match /users/{uid} {
      allow get:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      // Tạo lần đầu khi đăng nhập: bắt buộc approved=false và KHÔNG được kèm paidUntil
      // → user không thể tự mở khoá / tự gia hạn.
      allow create: if request.auth != null && request.auth.uid == uid
                 && request.resource.data.approved == false
                 && !('paidUntil' in request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Thành tích từng câu (đồng bộ theo tài khoản).
    match /stats/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if isAdmin();           // admin xem thành tích người khác
    }

    // Bảng xếp hạng công khai (chỉ biệt danh + điểm, không có thông tin riêng).
    match /leaderboard/{uid} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Cờ bật/tắt cổng toàn cục (đọc công khai để cả người chưa đăng nhập biết cổng mở hay đóng).
    match /config/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Báo đã chuyển khoản. Admin update được để xoá cờ "claimed" khi gia hạn.
    match /payments/{uid} {
      allow get:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create, update: if (request.auth != null && request.auth.uid == uid) || isAdmin();
    }

    // Hồ sơ cá nhân — tên thật CHỈ chủ tài khoản và admin đọc được (không public).
    match /profiles/{uid} {
      allow get:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }
  }
}
