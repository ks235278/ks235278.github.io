rules_version = '2';

// Firestore Security Rules HỢP NHẤT cho project n1-quiz (gồm cả app N1 quiz + app Tango).
// Dán TOÀN BỘ nội dung này vào: Firebase Console → Firestore Database → Rules → Publish.
// (File này thay thế hoàn toàn n1-quiz/firestore.rules — đã bao gồm nguyên vẹn phần cũ.)
//
// Nguyên tắc Tango: client KHÔNG BAO GIỜ ghi được bất cứ thứ gì dính đến xu.
// Chỉ Cloud Functions (Admin SDK, đi vòng qua rules) và admin (qua callable riêng) ghi được.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && (request.auth.token.email == 'ks235278@kaichi.ac.jp'
              || request.auth.token.admin == true);
    }

    // ══════════════════ N1 QUIZ (giữ nguyên như cũ) ══════════════════

    // Hồ sơ tài khoản. Hạn dùng (paidUntil) & approved CHỈ admin được ghi.
    match /users/{uid} {
      allow get:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create: if request.auth != null && request.auth.uid == uid
                 && request.resource.data.approved == false
                 && !('paidUntil' in request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Thành tích từng câu (đồng bộ theo tài khoản).
    match /stats/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    // Bảng xếp hạng công khai.
    match /leaderboard/{uid} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Cờ cấu hình toàn cục N1 quiz.
    match /config/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Báo đã chuyển khoản.
    match /payments/{uid} {
      allow get:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create, update: if (request.auth != null && request.auth.uid == uid) || isAdmin();
    }

    // Hồ sơ cá nhân — tên thật CHỈ chủ tài khoản và admin đọc được.
    match /profiles/{uid} {
      allow get:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }

    // ══════════════════ TANGO (app học từ vựng có thưởng xu ảo) ══════════════════

    // Cấu hình tango (eligibilityMinutes, testSize, cycleFee…) — đọc công khai, admin ghi.
    match /tango_config/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Ví xu. CHỈ server ghi. Chủ ví + admin đọc.
    match /tango_wallets/{uid} {
      allow get:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow write: if false;

      // Sổ cái append-only — client tuyệt đối không ghi (kể cả admin: đi qua callable).
      match /ledger/{entryId} {
        allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow write: if false;
      }
    }

    // Chu kỳ thưởng. CHỈ server ghi (rewardMeter, servedIds, lastTestDay… đều là tiền).
    match /tango_cycles/{cycleId} {
      allow read:  if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // Bài thi chính thức: đề + kết quả. CHỈ server ghi. Chủ bài + admin đọc.
    match /tango_tests/{testId} {
      allow read:  if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // Đáp án đúng của bài thi — KHÔNG AI đọc/ghi từ client. Chỉ Admin SDK.
    match /tango_answers/{testId} {
      allow read, write: if false;
    }

    // Tiến độ học từng mục. Chủ tài khoản ghi được, NHƯNG:
    //  - create: learnedAt bắt buộc == request.time (client phải dùng serverTimestamp,
    //    không thể lùi ngày để mục "chín" sớm → chống gian lận điều kiện thi)
    //  - update: learnedAt bất biến.
    match /tango_userItems/{uid}/items/{itemId} {
      allow read:   if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid
                 && request.resource.data.learnedAt == request.time;
      allow update: if request.auth != null && request.auth.uid == uid
                 && request.resource.data.learnedAt == resource.data.learnedAt;
      allow delete: if false;
    }

    // Sổ đăng ký user Tango — user tự ghi hồ sơ mình; admin liệt kê được tất cả.
    // Không dính xu, nên client ghi thẳng hồ sơ của chính mình.
    match /tango_users/{uid} {
      allow get:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    // Tin nhắn giữa user và admin. Mỗi user một luồng /tango_threads/{uid}.
    // Không dính xu → client được ghi, nhưng chỉ luồng của CHÍNH MÌNH và chỉ
    // dán nhãn from == 'user'; admin dán nhãn from == 'admin'. Tin đã gửi bất biến.
    match /tango_threads/{uid} {
      allow get:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create, update: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow create: if request.auth != null
                   && request.resource.data.text is string
                   && request.resource.data.text.size() > 0
                   && request.resource.data.text.size() <= 2000
                   && request.resource.data.createdAt == request.time
                   && (
                        (request.auth.uid == uid && request.resource.data.from == 'user')
                     || (isAdmin() && request.resource.data.from == 'admin')
                      );
        allow update, delete: if isAdmin();
      }
    }
  }
}
